{
  "version": 2,
  "builds": [
    {
      "src": "src/core/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.11"
      }
    },
    {
      "src": "build.sh",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "assets/staticfiles"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/assets/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "src/core/wsgi.py"
    }
  ]
}
